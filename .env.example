# SDKWork Video Cut desktop shell
#
# The current AutoCut frontend runs with local mock services inside packages.
# Keep model, FFmpeg, host, and credential settings out of the browser bundle
# until a dedicated Tauri/Host integration owns those contracts.
DISABLE_HMR=false

# Framework database lifecycle (CLI / CI via sdkwork-database-cli)
# SDKWORK_VIDEO_CUT_DATABASE_URL=sqlite:///absolute/path/to/videocut.sqlite3
# SDKWORK_VIDEO_CUT_DATABASE_ENGINE=sqlite
# SDKWORK_VIDEO_CUT_APP_ROOT=.

# Desktop Tauri sqlite runtime override (optional)
# SDKWORK_AUTOCUT_SQLITE_FILE=C:/path/to/sdkwork-autocut.sqlite3
