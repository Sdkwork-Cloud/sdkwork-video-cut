{
  "schemaId": "video-cut.model-manifest.v1",
  "modelId": "silero-vad-onnx",
  "displayName": "Silero VAD ONNX",
  "artifactFile": "silero-vad.onnx",
  "distribution": "user-provided",
  "requiredForMvp": false,
  "runtime": {
    "engine": "onnxruntime",
    "rustAdapter": "ort",
    "executionProvider": "cpu"
  },
  "audioContract": {
    "sampleRate": 16000,
    "channels": 1,
    "format": "wav",
    "codec": "pcm_s16le",
    "frameSamples": 512
  },
  "expectedInputs": [
    { "name": "input", "type": "float32", "shape": [1, 512] },
    { "name": "state", "type": "float32", "shape": [2, 1, 128], "optional": true },
    { "name": "sr", "type": "int64", "shape": [], "optional": true }
  ],
  "expectedOutputs": [
    { "name": "output", "type": "float32" },
    { "name": "stateN", "type": "float32", "optional": true }
  ],
  "configuration": {
    "settingsFlag": "mediaTools.onnxRuntimeEnabled",
    "modelPathSetting": "mediaTools.sileroVadModelPath",
    "defaultModelPath": "models/silero-vad.onnx"
  },
  "security": {
    "networkAccessAtRuntime": false,
    "secretAccess": false,
    "notes": "The model file is loaded from the configured local/server filesystem path. The host does not download models at runtime."
  }
}
