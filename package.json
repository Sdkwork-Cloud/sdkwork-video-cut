{
  "name": "@sdkwork/video-cut",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@10.30.2",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "pnpm --filter @sdkwork/autocut-desktop dev",
    "dev:tauri-web": "pnpm --filter @sdkwork/autocut-desktop dev:tauri-web",
    "build": "pnpm -r --filter \"./packages/*\" --filter \"!@sdkwork/autocut-desktop\" build && pnpm --filter @sdkwork/autocut-desktop build",
    "preview": "pnpm --filter @sdkwork/autocut-desktop preview",
    "clean": "node scripts/clean-autocut-generated.mjs",
    "check:autocut-architecture": "node scripts/check-autocut-architecture.mjs",
    "prepare:ffmpeg-sidecar": "node scripts/prepare-autocut-ffmpeg-sidecar.mjs",
    "release:smoke-preflight": "node scripts/check-autocut-release-smoke-preflight.mjs",
    "release:native-smoke": "node scripts/write-autocut-native-release-smoke.mjs",
    "release:installer-signature": "node scripts/write-autocut-installer-signature-evidence.mjs",
    "release:evidence": "node scripts/write-autocut-release-evidence.mjs",
    "release:commercial-ready": "node scripts/check-autocut-commercial-release-readiness.mjs",
    "lint": "pnpm check:autocut-architecture && pnpm typecheck",
    "typecheck": "pnpm -r --filter \"./packages/*\" typecheck && tsc --noEmit",
    "test": "pnpm check:autocut-architecture && node scripts/check-autocut-feature-workflows.mjs && node scripts/check-autocut-service-behavior.mjs && node scripts/ensure-autocut-tauri-rust-toolchain.test.mjs && node scripts/prepare-autocut-ffmpeg-sidecar.test.mjs && node scripts/check-autocut-release-smoke-preflight.test.mjs && node scripts/write-autocut-native-release-smoke.test.mjs && node scripts/write-autocut-installer-signature-evidence.test.mjs && node scripts/write-autocut-release-evidence.test.mjs && node scripts/check-autocut-commercial-release-readiness.test.mjs && pnpm -r --filter \"./packages/*\" test",
    "tauri:before-dev": "pnpm --filter @sdkwork/autocut-desktop tauri:before-dev",
    "tauri:dev": "pnpm --filter @sdkwork/autocut-desktop tauri:dev",
    "tauri:build": "pnpm --filter @sdkwork/autocut-desktop tauri:build"
  },
  "dependencies": {
    "@sdkwork/autocut-desktop": "workspace:*"
  },
  "devDependencies": {
    "@tailwindcss/vite": "catalog:",
    "@tauri-apps/api": "catalog:",
    "@tauri-apps/cli": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitejs/plugin-react": "catalog:",
    "tailwindcss": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:"
  }
}
