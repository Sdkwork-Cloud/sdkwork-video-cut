{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SDKWork Video Cut",
  "version": "0.1.0",
  "identifier": "com.sdkwork.video-cut",
  "build": {
    "beforeDevCommand": "pnpm tauri:before-dev",
    "devUrl": "http://127.0.0.1:5173",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "SDKWork Video Cut",
        "width": 1440,
        "height": 960,
        "minWidth": 1180,
        "minHeight": 760,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.ico"
    ]
  }
}
