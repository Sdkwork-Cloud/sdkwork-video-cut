{
  "name": "@sdkwork/autocut-desktop",
  "version": "0.1.6",
  "license": "SEE LICENSE IN LICENSE",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node ../../scripts/run-autocut-vite.mjs --host 127.0.0.1 --port 3000 --strictPort",
    "dev:tauri-web": "node ../../scripts/run-autocut-vite.mjs --host 127.0.0.1 --port 5173 --strictPort",
    "build": "node ../../scripts/run-autocut-vite.mjs build",
    "preview": "node ../../scripts/run-autocut-vite.mjs preview",
    "typecheck": "tsc --noEmit",
    "test": "tsc --noEmit",
    "tauri:before-dev": "pnpm dev:tauri-web",
    "tauri:dev": "node ../../scripts/ensure-autocut-tauri-rust-toolchain.mjs && pnpm exec tauri dev",
    "tauri:build": "node ../../scripts/ensure-autocut-tauri-rust-toolchain.mjs && node ../../scripts/prepare-autocut-speech-sidecar.mjs --check --require-bundled && pnpm exec tauri build"
  },
  "dependencies": {
    "@sdkwork/autocut-assets": "workspace:*",
    "@sdkwork/autocut-commons": "workspace:*",
    "@sdkwork/autocut-core": "workspace:*",
    "@sdkwork/autocut-extractor-audio": "workspace:*",
    "@sdkwork/autocut-extractor-text": "workspace:*",
    "@sdkwork/autocut-home": "workspace:*",
    "@sdkwork/autocut-messages": "workspace:*",
    "@sdkwork/autocut-settings": "workspace:*",
    "@sdkwork/autocut-services": "workspace:*",
    "@sdkwork/autocut-slicer": "workspace:*",
    "@sdkwork/autocut-subtitle-translate": "workspace:*",
    "@sdkwork/autocut-tasks": "workspace:*",
    "@sdkwork/autocut-tools": "workspace:*",
    "@sdkwork/autocut-types": "workspace:*",
    "@sdkwork/autocut-video-compress": "workspace:*",
    "@sdkwork/autocut-video-convert": "workspace:*",
    "@sdkwork/autocut-video-dedup": "workspace:*",
    "@sdkwork/autocut-video-enhance": "workspace:*",
    "@sdkwork/autocut-video-gif": "workspace:*",
    "@sdkwork/autocut-voice-translate": "workspace:*",
    "@tauri-apps/api": "catalog:",
    "lucide-react": "catalog:",
    "pixi.js": "catalog:",
    "react": "catalog:",
    "react-dom": "catalog:",
    "react-i18next": "catalog:",
    "react-router-dom": "catalog:"
  },
  "devDependencies": {
    "@tailwindcss/vite": "catalog:",
    "@tauri-apps/cli": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@vitejs/plugin-react": "catalog:",
    "tailwindcss": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:"
  },
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "import": "./src/index.ts",
      "types": "./src/index.ts"
    }
  }
}
