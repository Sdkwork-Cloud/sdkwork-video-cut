{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SDKWork Video Cut",
  "version": "0.1.4",
  "identifier": "com.sdkwork.video-cut",
  "build": {
    "beforeDevCommand": "pnpm tauri:before-dev",
    "devUrl": "http://127.0.0.1:5173",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "SDKWork Video Cut",
        "width": 1440,
        "height": 960,
        "minWidth": 1180,
        "minHeight": 760,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: asset: http://asset.localhost; font-src 'self' data:; media-src 'self' blob: asset: http://asset.localhost; connect-src 'self' http://127.0.0.1:5173 ws://127.0.0.1:5173; worker-src 'self' blob:; object-src 'none'; base-uri 'self'; frame-ancestors 'none'",
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$APPDATA/**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": {
      "binaries/ffmpeg.toolchain.json": "binaries/ffmpeg.toolchain.json",
      "binaries/speech-transcription.toolchain.json": "binaries/speech-transcription.toolchain.json",
      "binaries/windows-x86_64": "binaries/windows-x86_64",
      "binaries/linux-x86_64": "binaries/linux-x86_64",
      "binaries/macos-x86_64": "binaries/macos-x86_64",
      "binaries/macos-aarch64": "binaries/macos-aarch64"
    },
    "icon": [
      "icons/icon.ico"
    ]
  }
}
