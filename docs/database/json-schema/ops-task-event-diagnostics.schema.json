{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "video-cut.database.ops-task-event-diagnostics.schema.v1",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "providerId": { "type": "string" },
    "logPath": { "type": "string" },
    "traceId": { "type": "string" },
    "recoveryHint": {
      "type": "object",
      "required": ["code", "action", "label", "message", "retryable"],
      "additionalProperties": false,
      "properties": {
        "code": { "type": "string" },
        "action": {
          "enum": [
            "upload-source",
            "retry-analysis",
            "retry-render",
            "open-settings",
            "open-diagnostics",
            "review-render-log",
            "none"
          ]
        },
        "label": { "type": "string" },
        "message": { "type": "string" },
        "retryable": { "type": "boolean" },
        "targetStage": { "type": "string" }
      }
    }
  }
}
